<rdf:RDF xml:base="http://example.org/chebi-like"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
  <owl:Class rdf:about="http://example.org/chebi-like#CHEBI_1">
    <oboInOwl:id>CHEBI:1</oboInOwl:id>
  </owl:Class>
  <owl:Axiom>
    <owl:annotatedSource rdf:resource="http://example.org/chebi-like#CHEBI_1"/>
    <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym"/>
    <owl:annotatedTarget>Example brand</owl:annotatedTarget>
    <oboInOwl:hasSynonymType rdf:resource="http://purl.obolibrary.org/obo/chebi/BRAND_NAME"/>
  </owl:Axiom>
</rdf:RDF>

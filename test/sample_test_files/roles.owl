<rdf:RDF xml:base="http://example.org/roles"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#">
  <owl:FunctionalProperty rdf:about="#has_owner">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <Code>MO_278</Code>
  </owl:FunctionalProperty>
  <owl:Class rdf:about="#Person"><Code>MO_24</Code></owl:Class>
  <owl:Class rdf:about="#BioSourceProvider">
    <Code>MO_230</Code>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="#has_owner"/>
        <owl:someValuesFrom rdf:resource="#Person"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
</rdf:RDF>
